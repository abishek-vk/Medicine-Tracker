{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs'); fs.rmSync('package-lock.json',{force:true}); fs.rmSync('yarn.lock',{force:true});\"",
    "dev": "pnpm run --parallel dev:server dev:frontend",
    "dev:frontend": "pnpm --filter @workspace/medicine-tracker dev",
    "dev:server": "pnpm --filter @workspace/api-server dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "dependencies": {},
  "devDependencies": {
    "prettier": "^3.9.4",
    "typescript": "~5.9.3"
  }
}
